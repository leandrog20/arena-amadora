# ============================================================
# AMBIENTE
# ============================================================
NODE_ENV=development
PORT=3333
HOST=0.0.0.0

# ============================================================
# BANCO DE DADOS — SUPABASE
# ============================================================
# Conexão via PgBouncer (porta 6543) — usada em runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Conexão direta (porta 5432) — usada pelo Prisma CLI para migrations
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ============================================================
# SUPABASE CONFIG (opcional — necessário para uploads)
# ============================================================
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ============================================================
# JWT — use secrets fortes em produção (mín. 32 chars aleatórios)
# ============================================================
JWT_SECRET="CHANGE_ME_use_openssl_rand_base64_32"
JWT_REFRESH_SECRET="CHANGE_ME_use_openssl_rand_base64_32"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ============================================================
# E-MAIL (Resend) — necessário para reset de senha
# ============================================================
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Arena Amadora <noreply@seudominio.com>"

# ============================================================
# REDIS (opcional — app funciona sem, mas sem cache)
# ============================================================
REDIS_URL="redis://localhost:6379"

# ============================================================
# FRONTEND URL (CORS)
# ============================================================
# Pode ser múltiplas URLs separadas por vírgula para produção
# Ex: "https://arena-amadora.com,https://www.arena-amadora.com"
FRONTEND_URL="http://localhost:3000"

# ============================================================
# UPLOADS
# ============================================================
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880

# ============================================================
# PLATAFORMA
# ============================================================
PLATFORM_FEE_PERCENTAGE=10

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
